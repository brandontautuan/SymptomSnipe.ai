{
  "mcpServers": {
    "tavily": {
      "command": "npx",
      "args": ["-y", "tavily-mcp@0.1.4"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    },
    "github": {
      "type": "sse",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "env": {}
    },
    "reconstruct": {
      "type": "http",
      "url": "https://reconstructmcp-production.up.railway.app/",
      "headers": {
        "Authorization": "Bearer ${RECONSTRUCT_API_KEY}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/mathewrolf/Desktop/SymptomSnipe.ai/SymptomSnipe.ai"
      ]
    }
  }
}
